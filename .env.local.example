# Copy to .env.local — never commit real secrets. Set the same keys in Vercel → Environment Variables.

# ── Supabase (required for auth, portal, APIs) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt

# Optional: newer Supabase publishable keys — this app uses ANON_KEY above for @supabase/ssr.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# ── Site URL — production must be the live domain (SEO, OG, sitemap, JSON-LD)
NEXT_PUBLIC_APP_URL=https://alevelbusinessconsultants.co.za

# Google Search Console (HTML tag verification — content string only)
GOOGLE_SITE_VERIFICATION=

# ── Email (contact / notifications) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ABC INC <noreply@alevelbusinessconsultants.co.za>"
ADMIN_EMAIL=
